---
import Layout from '@/app.astro'
import Hero from '@/components/Hero.astro'
import Container from '@/components/Container.astro'
import { getPgMainContent } from '@/services/contentful.ts'
import SectionsHandler from '@/components/sections/SectionHandler.astro'

const { head, sections, footer, ...heroProps } = await getPgMainContent()

const haveSections = sections && sections?.length > 0
const haveFooterAnnouncement = footer?.announcement != null
---

<Layout {...head} {footer}>
  <Container unlimited as="main">
    <Hero {...heroProps} />
    {haveSections && <SectionsHandler {sections} class:list={{ 'pb-40 lg:pb-24': haveFooterAnnouncement }} />}
  </Container>
</Layout>
